generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Event {
  id          String   @id @default(cuid()) @db.VarChar(30)
  title       String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(191)
  description String   @db.Text
  city        String   @db.VarChar(255)
  location    String   @db.VarChar(255)
  bannerUrl   String?  @db.VarChar(512)
  logoUrl     String?  @db.VarChar(512)

  registrationStart DateTime
  registrationEnd   DateTime
  eventDate         DateTime

  status String @default("draft") @db.VarChar(20) // draft | open | closed | finished

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groups        Group[]
  registrations Registration[]
}

model Group {
  id       String @id @default(cuid()) @db.VarChar(30)
  eventId  String @db.VarChar(30)
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name       String  @db.VarChar(255)
  distance   Float
  startTime  String  @db.VarChar(20)
  cutoffTime String  @db.VarChar(20)

  gender   String  @default("all") @db.VarChar(10) // male | female | all
  minAge   Int?
  maxAge   Int?
  capacity Int
  fee      Int // unit: fen
  isOpen   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  registrations Registration[]

  @@index([eventId])
}

model Runner {
  id       String  @id @default(cuid()) @db.VarChar(30)
  phone    String  @unique @db.VarChar(20)
  password String  @db.VarChar(255) // scrypt-hashed: salt:hash
  name     String  @db.VarChar(255)
  uraId    Int?    @unique // 5-digit random URA ID, immutable by user
  gender   String  @db.VarChar(10)
  idCard   String  @db.VarChar(18)
  email    String? @db.VarChar(255)
  school   String  @db.VarChar(255)
  major    String? @db.VarChar(255)

  sessionToken String? @unique @db.VarChar(191)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  registrations Registration[]
}

model Registration {
  id      String @id @default(cuid()) @db.VarChar(30)
  eventId String @db.VarChar(30)
  event   Event  @relation(fields: [eventId], references: [id])

  groupId String @db.VarChar(30)
  group   Group  @relation(fields: [groupId], references: [id])

  name   String @db.VarChar(255)
  gender String @db.VarChar(10)
  idCard String @db.VarChar(18)
  phone  String @db.VarChar(20)
  email  String? @db.VarChar(255)
  school String @db.VarChar(255)
  major  String? @db.VarChar(255)

  runnerId String? @db.VarChar(30)
  runner   Runner? @relation(fields: [runnerId], references: [id])

  emergencyContact String @db.VarChar(255)
  emergencyPhone   String @db.VarChar(20)

  status String @default("pending_payment") @db.VarChar(20) // pending_payment | paid | cancelled

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, groupId, idCard])
  @@index([eventId])
  @@index([groupId])
  @@index([idCard, phone])
}
model Article {
  id          String   @id @default(cuid()) @db.VarChar(30)
  slug        String   @unique @db.VarChar(191)
  title       String   @db.VarChar(255)
  subtitle    String?  @db.VarChar(255)
  category    String   @db.VarChar(20) // platform | interview | race
  author      String?  @db.VarChar(255)
  excerpt     String   @db.Text
  coverTag    String?  @db.VarChar(191)
  coverMeta   String?  @db.VarChar(191)
  coverUrl    String?  @db.VarChar(512)
  content     String   @db.LongText // markdown source
  status      String   @default("draft") @db.VarChar(20) // draft | published
  featured    Boolean  @default(false)
  readMinutes Int      @default(3)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, status])
  @@index([status, publishedAt])
}
